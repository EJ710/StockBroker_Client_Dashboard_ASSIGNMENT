# ---------------------------------------------------------------------------
# Optional frontend configuration.
#
# Copy this file to ".env" only if you need to override a default:
#     cp .env.example .env
#
# The app runs fine with NO .env file — these are just escape hatches for when
# a port is already in use on your machine.
# ---------------------------------------------------------------------------

# Preferred dev-server port. If this port is busy, Vite automatically uses the
# next free one, so the app still starts either way.
VITE_PORT=5173

# Where the backend API is running. Change this if you start the backend on a
# different port (e.g. http://localhost:8001). The WebSocket URL is derived
# from it automatically.
VITE_API_TARGET=http://localhost:8000
