# ---------------------------------------------------------------------------
# Example environment configuration.
#
# Copy this file to ".env" and adjust as needed:
#     cp .env.example .env
#
# Every value here has a sensible default in app/config.py, so the app runs
# out of the box even with NO .env file at all. You only need this file if you
# want to (a) send REAL OTP emails, or (b) change ports/secrets for deployment.
# ---------------------------------------------------------------------------

# --- Security -------------------------------------------------------------
# Secret used to sign JWT session tokens. CHANGE THIS in production.
JWT_SECRET=change-me-to-a-long-random-string

# How long a login session (JWT) stays valid, in minutes.
JWT_EXPIRE_MINUTES=720

# --- OTP behaviour --------------------------------------------------------
# How long a one-time code is valid, in seconds (default 300 = 5 minutes).
OTP_TTL_SECONDS=300

# DEV_MODE=true  -> the OTP code is logged to the server console AND returned
#                   in the API response, so you can log in without any email
#                   setup. Perfect for local development / grading.
# DEV_MODE=false -> the code is ONLY delivered by email (see SMTP_* below) and
#                   never exposed in the API response. Use this for "real" mode.
DEV_MODE=true

# --- SMTP (only used when you want REAL emails) ---------------------------
# Leave these blank to keep using DEV_MODE console delivery.
# Example for Gmail: host=smtp.gmail.com port=587, user=you@gmail.com,
# password=<a Google "App Password">, from=you@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- CORS -----------------------------------------------------------------
# Comma-separated list of frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Price engine ---------------------------------------------------------
# How often (seconds) the simulated prices tick. Brief asks for 1 second.
PRICE_TICK_SECONDS=1
